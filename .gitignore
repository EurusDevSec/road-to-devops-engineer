# Local .terraform directory (chứa plugin, nặng và không cần thiết)
.terraform/

# State files (Chứa TOÀN BỘ thông tin hạ tầng, bao gồm cả mật khẩu/secret dạng clear text)
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Các file chứa giá trị biến thực tế (thường chứa secret key)
terraform.tfvars
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json

# bash file
*.sh
